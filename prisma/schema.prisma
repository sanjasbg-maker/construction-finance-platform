// NextFinancial Control 2.0 - data model
// Construction finance app: Payables, Receivables, Bank Statements, Projects,
// Vendors, Clients, Settings, Reports, Data all read/write these models.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Settings ----------

model Company {
  id        String   @id @default(cuid())
  name      String
  taxId     String?
  currency  String   @default("EUR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users      User[]
  vendors    Vendor[]
  clients    Client[]
  projects   Project[]
  costCodes  CostCode[]
  bankAccounts BankAccount[]
}

enum UserRole {
  OWNER
  ACCOUNTANT
  VIEWER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      UserRole @default(VIEWER)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())

  auditLogs AuditLog[]
}

model CostCode {
  id        String   @id @default(cuid())
  code      String
  name      String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  bills    Bill[]
  invoices Invoice[]

  @@unique([companyId, code])
}

// ---------- Vendors / Clients ----------

model Vendor {
  id            String   @id @default(cuid())
  name          String
  taxId         String?
  email         String?
  phone         String?
  paymentTerms  String?
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())

  bills Bill[]
}

model Client {
  id        String   @id @default(cuid())
  name      String
  taxId     String?
  email     String?
  phone     String?
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())

  invoices Invoice[]
  projects Project[]
}

// ---------- Projects ----------

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
}

model Project {
  id        String        @id @default(cuid())
  name      String
  code      String
  status    ProjectStatus @default(PLANNED)
  budget    Decimal       @default(0) @db.Decimal(14, 2)
  startDate DateTime?
  endDate   DateTime?
  companyId String
  company   Company       @relation(fields: [companyId], references: [id])
  clientId  String?
  client    Client?       @relation(fields: [clientId], references: [id])
  createdAt DateTime      @default(now())

  bills    Bill[]
  invoices Invoice[]

  @@unique([companyId, code])
}

// ---------- Payables (AP) ----------

enum BillStatus {
  DRAFT
  APPROVED
  PARTIALLY_PAID
  PAID
  OVERDUE
}

model Bill {
  id          String     @id @default(cuid())
  number      String
  amount      Decimal    @db.Decimal(14, 2)
  issueDate   DateTime
  dueDate     DateTime
  status      BillStatus @default(DRAFT)
  vendorId    String
  vendor      Vendor     @relation(fields: [vendorId], references: [id])
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id])
  costCodeId  String?
  costCode    CostCode?  @relation(fields: [costCodeId], references: [id])
  createdAt   DateTime   @default(now())

  payments    Payment[]
  attachments Attachment[]
}

// ---------- Receivables (AR) ----------

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
}

model Invoice {
  id          String        @id @default(cuid())
  number      String
  amount      Decimal       @db.Decimal(14, 2)
  issueDate   DateTime
  dueDate     DateTime
  status      InvoiceStatus @default(DRAFT)
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id])
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id])
  costCodeId  String?
  costCode    CostCode?     @relation(fields: [costCodeId], references: [id])
  createdAt   DateTime      @default(now())

  payments    Payment[]
  attachments Attachment[]
}

// ---------- Payments (links AP/AR to money movement) ----------

enum PaymentDirection {
  INCOMING
  OUTGOING
}

model Payment {
  id          String           @id @default(cuid())
  amount      Decimal          @db.Decimal(14, 2)
  date        DateTime
  direction   PaymentDirection
  billId      String?
  bill        Bill?            @relation(fields: [billId], references: [id])
  invoiceId   String?
  invoice     Invoice?         @relation(fields: [invoiceId], references: [id])
  bankTxId    String?          @unique
  bankTx      BankTransaction? @relation(fields: [bankTxId], references: [id])
  createdAt   DateTime         @default(now())
}

// ---------- Bank Statements ----------

model BankAccount {
  id         String   @id @default(cuid())
  name       String
  iban       String?
  currency   String   @default("EUR")
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])

  statements BankStatement[]
}

model BankStatement {
  id            String   @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  fileName      String
  importedAt    DateTime @default(now())
  periodStart   DateTime?
  periodEnd     DateTime?

  transactions BankTransaction[]
  attachment   Attachment?
}

model BankTransaction {
  id              String   @id @default(cuid())
  bankStatementId String
  bankStatement   BankStatement @relation(fields: [bankStatementId], references: [id])
  date            DateTime
  description     String
  amount          Decimal  @db.Decimal(14, 2)
  reconciled      Boolean  @default(false)

  payment Payment?
}

// ---------- Data (attachments / imports) ----------

model Attachment {
  id              String         @id @default(cuid())
  fileName        String
  url             String
  mimeType        String
  uploadedAt      DateTime       @default(now())
  billId          String?
  bill            Bill?          @relation(fields: [billId], references: [id])
  invoiceId       String?
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id])
  bankStatementId String?        @unique
  bankStatement   BankStatement? @relation(fields: [bankStatementId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
