// Construction Finance Platform - data model
// See CLAUDE.md and BUSINESS_RULES.md for the source spec, and
// .claude/plans/playful-spinning-diffie.md (in the user's home dir) for the
// architectural decisions behind this schema.
//
// Base-fields convention: every model has id/createdAt/updatedAt/createdBy/updatedBy/
// deletedAt EXCEPT AuditLog and ExchangeRate, which are append-only by design.
// createdBy/updatedBy are loose user-id strings, not relations (see plan decision #1).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------- Enums ----------

enum UserRole {
  ADMIN
  DIRECTOR
  FINANCE
  PROJECT_MANAGER
  VIEWER
}

enum Currency {
  EUR
  RSD
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ContractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  TERMINATED
}

enum PurchaseInvoiceStatus {
  RECEIVED
  WAITING_PM_APPROVAL
  APPROVED
  WAITING_DIRECTOR_APPROVAL
  READY_FOR_PAYMENT
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum SalesInvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum SituationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ApprovalStepRole {
  PROJECT_MANAGER
  FINANCE
  DIRECTOR
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum PaymentDirection {
  IN
  OUT
}

enum PaymentType {
  VENDOR_ADVANCE
  CLIENT_ADVANCE
  INVOICE_SETTLEMENT
  RETENTION_RELEASE
}

enum RetentionDirection {
  CLIENT_FROM_COMPANY
  COMPANY_FROM_VENDOR
}

enum RetentionStatus {
  HELD
  PARTIALLY_RELEASED
  RELEASED
}

enum GuaranteeType {
  PERFORMANCE
  ADVANCE_PAYMENT
  WARRANTY
}

enum GuaranteeStatus {
  ACTIVE
  RELEASED
  EXPIRED
  CALLED
}

enum DocumentCategory {
  CONTRACT
  AMENDMENT
  INVOICE
  BANK_STATEMENT
  GUARANTEE
  PHOTO
  CORRESPONDENCE
  OTHER
}

// ---------- Administration ----------

model User {
  id    String   @id @default(cuid())
  name  String
  email String   @unique
  role  UserRole @default(VIEWER)
  // Null means no password has been set yet - that user cannot log in until
  // an ADMIN sets one via Administration (see src/lib/auth.ts / Session below).
  passwordHash String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  pmAssignments     ProjectManagerAssignment[]
  approvalSteps     ApprovalStep[]
  situationsActedOn Situation[]
  sessions          Session[]
}

// Real login sessions. The raw token lives only in an httpOnly cookie; only
// its SHA-256 hash is stored here, so a DB leak alone can't be used to hijack
// a session. Deleting a row logs that session out immediately.
model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ---------- Clients / Vendors ----------

model Client {
  id    String  @id @default(cuid())
  name  String
  taxId String?
  email String?
  phone String?
  // Lump-sum receivable carried over from a previous accounting system as of
  // when this client started being tracked here - not tied to a specific
  // invoice (see plan decision on Vendor/Client opening balances).
  openingBalance         Decimal  @default(0) @db.Decimal(14, 2)
  openingBalanceCurrency Currency @default(EUR)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  projects      Project[]
  salesInvoices SalesInvoice[]
  payments      Payment[]
}

model Vendor {
  id           String  @id @default(cuid())
  name         String
  taxId        String?
  email        String?
  phone        String?
  paymentTerms String?
  // Lump-sum payable carried over from a previous accounting system as of
  // when this vendor started being tracked here - not tied to a specific
  // invoice (see plan decision on Vendor/Client opening balances).
  openingBalance         Decimal  @default(0) @db.Decimal(14, 2)
  openingBalanceCurrency Currency @default(EUR)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  purchaseInvoices PurchaseInvoice[]
  payments         Payment[]
}

// ---------- Projects ----------

model Project {
  id        String        @id @default(cuid())
  name      String
  code      String        @unique
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id])
  status    ProjectStatus @default(ACTIVE)
  startDate DateTime?
  endDate   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  contracts        Contract[]
  purchaseInvoices PurchaseInvoice[]
  salesInvoices    SalesInvoice[]
  situations       Situation[]
  documents        Document[]
  guarantees       Guarantee[]
  pmAssignments    ProjectManagerAssignment[]
}

model ProjectManagerAssignment {
  id        String    @id @default(cuid())
  projectId String
  project   Project   @relation(fields: [projectId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  startDate DateTime
  endDate   DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
}

// ---------- Contracts ----------

model Contract {
  id               String         @id @default(cuid())
  number           String
  date             DateTime
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id])
  value            Decimal        @db.Decimal(14, 2)
  currency         Currency
  retentionPercent Decimal?       @db.Decimal(5, 2)
  status           ContractStatus @default(DRAFT)
  startDate        DateTime?
  endDate          DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  amendments       ContractAmendment[]
  purchaseInvoices PurchaseInvoice[]
  salesInvoices    SalesInvoice[]
  retentions       Retention[]
  guarantees       Guarantee[]
  documents        Document[]
  situations       Situation[]
}

model ContractAmendment {
  id            String   @id @default(cuid())
  contractId    String
  contract      Contract @relation(fields: [contractId], references: [id])
  number        String
  date          DateTime
  valueChange   Decimal  @db.Decimal(14, 2)
  newTotalValue Decimal  @db.Decimal(14, 2)
  reason        String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  documents Document[]
}

// ---------- Situations (progress / measurement certificates) ----------

model Situation {
  id         String          @id @default(cuid())
  number     String
  date       DateTime
  projectId  String
  project    Project         @relation(fields: [projectId], references: [id])
  contractId String?
  contract   Contract?       @relation(fields: [contractId], references: [id])
  amount     Decimal         @db.Decimal(14, 2)
  currency   Currency
  status     SituationStatus @default(DRAFT)
  approvedAt DateTime?
  approvedBy String?
  approver   User?           @relation(fields: [approvedBy], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  salesInvoices SalesInvoice[]
}

// ---------- Purchase Invoices (Vendor Invoices, received via SEF) ----------

model PurchaseInvoice {
  id         String                @id @default(cuid())
  number     String
  sefNumber  String?
  vendorId   String
  vendor     Vendor                @relation(fields: [vendorId], references: [id])
  projectId  String
  project    Project               @relation(fields: [projectId], references: [id])
  contractId String?
  contract   Contract?             @relation(fields: [contractId], references: [id])
  amount     Decimal               @db.Decimal(14, 2)
  currency   Currency
  issueDate  DateTime
  dueDate    DateTime
  status     PurchaseInvoiceStatus @default(RECEIVED)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  approvalSteps ApprovalStep[]
  allocations   PaymentAllocation[]
  retentions    Retention[]
  documents     Document[]
}

// ---------- Sales Invoices (Client Invoices) ----------

model SalesInvoice {
  id          String             @id @default(cuid())
  number      String
  clientId    String
  client      Client             @relation(fields: [clientId], references: [id])
  projectId   String
  project     Project            @relation(fields: [projectId], references: [id])
  contractId  String?
  contract    Contract?          @relation(fields: [contractId], references: [id])
  situationId String?
  situation   Situation?         @relation(fields: [situationId], references: [id])
  amount      Decimal            @db.Decimal(14, 2)
  currency    Currency
  issueDate   DateTime
  dueDate     DateTime
  status      SalesInvoiceStatus @default(DRAFT)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  allocations PaymentAllocation[]
  retentions  Retention[]
  documents   Document[]
}

// ---------- Approval workflow ----------

model ApprovalStep {
  id                String            @id @default(cuid())
  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice   @relation(fields: [purchaseInvoiceId], references: [id])
  role              ApprovalStepRole
  decision          ApprovalDecision?
  actedBy           String?
  actor             User?             @relation(fields: [actedBy], references: [id])
  comment           String?
  actedAt           DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
}

// ---------- Retention ----------

model Retention {
  id                String             @id @default(cuid())
  contractId        String
  contract          Contract           @relation(fields: [contractId], references: [id])
  direction         RetentionDirection
  purchaseInvoiceId String?
  purchaseInvoice   PurchaseInvoice?   @relation(fields: [purchaseInvoiceId], references: [id])
  salesInvoiceId    String?
  salesInvoice      SalesInvoice?      @relation(fields: [salesInvoiceId], references: [id])
  amount            Decimal            @db.Decimal(14, 2)
  currency          Currency
  percent           Decimal?           @db.Decimal(5, 2)
  status            RetentionStatus    @default(HELD)
  releaseDate       DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  releasePayment Payment?
}

// ---------- Guarantees ----------

model Guarantee {
  id             String          @id @default(cuid())
  type           GuaranteeType
  contractId     String?
  contract       Contract?       @relation(fields: [contractId], references: [id])
  projectId      String?
  project        Project?        @relation(fields: [projectId], references: [id])
  issueDate      DateTime
  expiryDate     DateTime
  amount         Decimal         @db.Decimal(14, 2)
  currency       Currency
  status         GuaranteeStatus @default(ACTIVE)
  bankName       String
  reminderSentAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  documents Document[]
}

// ---------- Bank Accounts / Statements ----------

model BankAccount {
  id       String   @id @default(cuid())
  name     String
  iban     String?
  currency Currency
  // Balance as of when this account started being tracked in the app (e.g.
  // migrating from a previous system) - Cash Position = this + net of all
  // recorded Payments, instead of assuming the account started at zero.
  openingBalance Decimal @default(0) @db.Decimal(14, 2)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  statements BankStatement[]
  payments   Payment[]
}

model BankStatement {
  id            String      @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  fileName      String
  importedAt    DateTime    @default(now())
  periodStart   DateTime?
  periodEnd     DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  transactions BankTransaction[]
  documents    Document[]
}

model BankTransaction {
  id              String        @id @default(cuid())
  bankStatementId String
  bankStatement   BankStatement @relation(fields: [bankStatementId], references: [id])
  date            DateTime
  description     String
  amount          Decimal       @db.Decimal(14, 2)
  reconciled      Boolean       @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  payment Payment?
}

// ---------- Treasury (Payments) ----------

model Payment {
  id                String           @id @default(cuid())
  direction         PaymentDirection
  type              PaymentType
  amount            Decimal          @db.Decimal(14, 2)
  currency          Currency
  date              DateTime
  bankAccountId     String
  bankAccount       BankAccount      @relation(fields: [bankAccountId], references: [id])
  vendorId          String?
  vendor            Vendor?          @relation(fields: [vendorId], references: [id])
  clientId          String?
  client            Client?          @relation(fields: [clientId], references: [id])
  retentionId       String?          @unique
  retention         Retention?       @relation(fields: [retentionId], references: [id])
  // Only set when type is VENDOR_ADVANCE or CLIENT_ADVANCE. Consumed/remaining
  // amounts are computed from `allocations`, not stored (see plan decision #5).
  originalAmount    Decimal?         @db.Decimal(14, 2)
  // Contractual recoupment rate for an advance (e.g. 20%) - when set, the
  // allocation UI suggests amount = advancePercent% x invoice amount instead
  // of requiring a fully manual figure per invoice. Only meaningful when type
  // is VENDOR_ADVANCE or CLIENT_ADVANCE; a suggestion, not an enforced rule,
  // since Finance can always override it (e.g. the final invoice needs to
  // consume whatever remains regardless of the percentage).
  advancePercent    Decimal?         @db.Decimal(5, 2)
  bankTransactionId String?          @unique
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  allocations PaymentAllocation[]
}

model PaymentAllocation {
  id                String           @id @default(cuid())
  paymentId         String
  payment           Payment          @relation(fields: [paymentId], references: [id])
  purchaseInvoiceId String?
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id])
  salesInvoiceId    String?
  salesInvoice      SalesInvoice?    @relation(fields: [salesInvoiceId], references: [id])
  amount            Decimal          @db.Decimal(14, 2)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
}

// ---------- Multi-currency ----------

// Append-only: historical exchange rates must never change, so no update/soft-delete
// fields exist on this model at all (see plan decision #4).
model ExchangeRate {
  id           String   @id @default(cuid())
  date         DateTime
  fromCurrency Currency
  toCurrency   Currency
  rate         Decimal  @db.Decimal(18, 6)
  createdAt    DateTime @default(now())
  createdBy    String?

  @@unique([date, fromCurrency, toCurrency])
}

// ---------- Documents ----------

model Document {
  id                  String             @id @default(cuid())
  category            DocumentCategory
  fileName            String
  url                 String
  mimeType            String
  projectId           String?
  project             Project?           @relation(fields: [projectId], references: [id])
  contractId          String?
  contract            Contract?          @relation(fields: [contractId], references: [id])
  contractAmendmentId String?
  contractAmendment   ContractAmendment? @relation(fields: [contractAmendmentId], references: [id])
  purchaseInvoiceId   String?
  purchaseInvoice     PurchaseInvoice?   @relation(fields: [purchaseInvoiceId], references: [id])
  salesInvoiceId      String?
  salesInvoice        SalesInvoice?      @relation(fields: [salesInvoiceId], references: [id])
  bankStatementId     String?
  bankStatement       BankStatement?     @relation(fields: [bankStatementId], references: [id])
  guaranteeId         String?
  guarantee           Guarantee?         @relation(fields: [guaranteeId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
}

// ---------- Audit ----------

// Append-only: an audit trail that could itself be edited/soft-deleted defeats its
// purpose, so this model is intentionally excluded from the base-fields convention
// (see plan decision #4).
model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  userId    String?
  oldValue  Json?
  newValue  Json?
  reason    String?
  createdAt DateTime @default(now())
}
